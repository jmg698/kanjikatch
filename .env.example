# Database (Neon PostgreSQL)
DATABASE_URL=

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Uploadthing
UPLOADTHING_TOKEN=

# Anthropic Claude API
ANTHROPIC_API_KEY=

# Sentry Error Monitoring
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Cost Protection (Package 0). All optional — defaults are in src/lib/cost-protection.ts.
# Set COST_PROTECTION_IP_HASH_SALT to a random per-environment secret in production
# so IP hashes aren't trivially reversible.
COST_PROTECTION_IP_HASH_SALT=
# COST_PROTECTION_GLOBAL_DAILY_USD=50
# COST_PROTECTION_PER_USER_DAILY_TOKENS=150000
# COST_PROTECTION_IP_WINDOW_SEC=60
# COST_PROTECTION_IP_MAX_REQUESTS=10

# Stripe Billing (Package 2). Required for /api/billing/* and /api/webhooks/stripe.
# Use sk_test_* / pk_test_* / whsec_* in development; switch to live keys in prod.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price IDs for the Pro tier. Create products in Stripe Dashboard, then paste
# the corresponding price IDs (price_*) here. Founder prices unlock the
# $7/$70 grandfathered tier for the first 100 paid users; standard is $10/$100.
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_PRICE_ID_PRO_ANNUAL=
STRIPE_PRICE_ID_PRO_FOUNDER_MONTHLY=
STRIPE_PRICE_ID_PRO_FOUNDER_ANNUAL=
# Public URL used to build success/cancel redirects from Checkout and Customer
# Portal. Falls back to http://localhost:3000 when unset.
NEXT_PUBLIC_APP_URL=
