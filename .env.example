# Database (Neon PostgreSQL)
DATABASE_URL=

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Uploadthing
UPLOADTHING_TOKEN=

# Anthropic Claude API
ANTHROPIC_API_KEY=

# Sentry Error Monitoring
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Cost Protection (Package 0). All optional — defaults are in src/lib/cost-protection.ts.
# Set COST_PROTECTION_IP_HASH_SALT to a random per-environment secret in production
# so IP hashes aren't trivially reversible.
COST_PROTECTION_IP_HASH_SALT=
# COST_PROTECTION_GLOBAL_DAILY_USD=50
# COST_PROTECTION_PER_USER_DAILY_TOKENS=150000
# COST_PROTECTION_IP_WINDOW_SEC=60
# COST_PROTECTION_IP_MAX_REQUESTS=10
